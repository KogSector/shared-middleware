# Shared Middleware .gitignore
# Universal
.DS_Store
Thumbs.db
*.swp
*.swo
.vscode/
.idea/
.git/

# Rust
/target
**/target/
**/*.rs.bk
Cargo.lock
rust/target/
rust/**/target/

# Python
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
env/
.pytest_cache/
.coverage
htmlcov/
*.egg-info/

# Node.js
node_modules/
dist/
build/
npm-debug.log
yarn-error.log
.pnpm-debug.log

# Build Artifacts
*.so
*.dylib
*.dll
